n_rep = 1000
x_horsepower = runif(n_rep, 300, 700)
beta0_log_prior = rnorm(n_rep, 11.4, 0.2)
beta1_log_prior = rnorm(n_rep, 0.001, 0.0005)
sigma_log_prior = rexp(n_rep, rate = 1 / 0.15)
log_y_price_predicted_mean = beta0_log_prior + beta1_log_prior * x_horsepower
y_price_predicted = exp(rnorm(n_rep, log_y_price_predicted_mean, sigma_log_prior))
plot(x_horsepower, y_price_predicted,
xlab = "Horsepower",
ylab = "Prior Predicted Price (USD)",
main = "Prior Predictive Distribution for Price (Log-linear Model - Adjusted Priors)",
col = "darkgreen",
pch = 20,
cex = 0.8,
ylim = c(0, quantile(y_price_predicted, 0.995, na.rm = TRUE) * 1.05))
Sports_car <- read.csv("C:/Users/Flami/Downloads/archive (2)/Sport car price.csv")
Sports_car_df <- Sports_car |>
filter(Horsepower >= 300) |>
select(Horsepower, Price..in.USD.) |>
mutate(Price..in.USD. = as.numeric(str_replace_all(Price..in.USD., "[$,]", ""))) |>
rename(Price = Price..in.USD.) |>
head(100)
library(tidyverse)
library(janitor)
library(viridis)
library(kableExtra)
library(ggmosaic)
library(brms)
library(bayesplot)
library(tidybayes)
library(ggplot2)
knitr::opts_chunk$set(
echo = TRUE,
warning = FALSE,
message = FALSE,
eval = FALSE
)
n_rep = 1000
x_horsepower = runif(n_rep, 300, 700)
beta0_log_prior = rnorm(n_rep, 11.4, 0.2)
beta1_log_prior = rnorm(n_rep, 0.001, 0.0005)
sigma_log_prior = rexp(n_rep, rate = 1 / 0.15)
log_y_price_predicted_mean = beta0_log_prior + beta1_log_prior * x_horsepower
y_price_predicted = exp(rnorm(n_rep, log_y_price_predicted_mean, sigma_log_prior))
plot(x_horsepower, y_price_predicted,
xlab = "Horsepower",
ylab = "Prior Predicted Price (USD)",
main = "Prior Predictive Distribution for Price (Log-linear Model - Adjusted Priors)",
col = "darkgreen",
pch = 20,
cex = 0.8,
ylim = c(0, quantile(y_price_predicted, 0.995, na.rm = TRUE) * 1.05))
Sports_car <- read.csv("C:/Users/Flami/Downloads/archive (2)/Sport car price.csv")
Sports_car_df <- Sports_car |>
filter(Horsepower >= 300) |>
select(Horsepower, Price..in.USD.) |>
mutate(Price..in.USD. = as.numeric(str_replace_all(Price..in.USD., "[$,]", ""))) |>
rename(Price = Price..in.USD.) |>
head(100)
Sports_car_df |>
head(10)
Sports_car_df |>
nrow()
prior_set_loglinear <- c(
prior(normal(11.4, 0.2), class = "b", coef = "Intercept"),
prior(normal(0.001, 0.0005), class = "b", coef = "Horsepower"),
prior(exponential(1 / 0.15), class = "sigma")
)
fit_loglinear <- brm(
formula = Price ~ Horsepower,
data = Sports_car_df,
family = lognormal(),
prior = prior_set_loglinear,
chains = 4,
iter = 4000,
warmup = 2000,
cores = 4,
seed = 42,
backend = "cmdstanr"
)
