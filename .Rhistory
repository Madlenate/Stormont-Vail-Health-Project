n = 10000
log_mu_prior = rnorm(n, log(150000), 0.5)
mu_prior = exp(log_mu_prior)
sigma_prior = rexp(n, rate = 0.00005)
summary_mu_prior = summary(mu_prior)
sd_mu_prior = sd(mu_prior)
summary_sigma_prior = summary(sigma_prior)
sd_sigma_prior = sd(sigma_prior)
ggplot(data.frame(mu_prior), aes(x = mu_prior)) +
geom_histogram(aes(y = after_stat(density)),
col = "red",
fill = "white") +
geom_density(col = "green",
linewidth = 1) +
labs(x = "Average Cost (mu)",
title = "Prior Distribution of Average Sports Car Cost (mu)") +
theme_bw()
library(tidyverse)
library(janitor)
library(viridis)
library(kableExtra)
library(ggmosaic)
library(brms)
library(bayesplot)
library(tidybayes)
library(ggplot2)
knitr::opts_chunk$set(
echo = TRUE,
warning = FALSE,
message = FALSE,
eval = FALSE
)
n = 10000
log_mu_prior = rnorm(n, log(150000), 0.5)
mu_prior = exp(log_mu_prior)
sigma_prior = rexp(n, rate = 0.00005)
summary_mu_prior = summary(mu_prior)
sd_mu_prior = sd(mu_prior)
summary_sigma_prior = summary(sigma_prior)
sd_sigma_prior = sd(sigma_prior)
ggplot(data.frame(mu_prior), aes(x = mu_prior)) +
geom_histogram(aes(y = after_stat(density)),
col = "red",
fill = "white") +
geom_density(col = "green",
linewidth = 1) +
labs(x = "Average Cost (mu)",
title = "Prior Distribution of Average Sports Car Cost (mu)") +
theme_bw()
ggplot(data.frame(sigma_prior), aes(x = sigma_prior)) +
geom_histogram(aes(y = after_stat(density)),
col = bayes_col["prior_predict"],
fill = "white") +
geom_density(col = bayes_col["prior_predict"],
linewidth = 1) +
labs(x = "Standard Deviation of Cost (sigma)",
title = "Prior Distribution of Standard Deviation (sigma)") +
theme_bw()
